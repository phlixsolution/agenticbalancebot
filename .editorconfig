root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C and C++ (firmware)
[*.{c,cpp,h,hpp}]
indent_style = space
indent_size = 4

# Python (data pipeline)
[*.py]
indent_style = space
indent_size = 2

# YAML (CI workflows, config)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# INI / PlatformIO
[*.ini]
indent_style = space
indent_size = 4

# Markdown
[*.md]
trim_trailing_whitespace = false
